<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#E8ECF0"
                app:strokeWidth="1dp">
                <ImageView
                    android:id="@+id/ivDeviceIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_monitor"
                    app:tint="#EA580C" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">
                <TextView
                    android:id="@+id/tvDeviceTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dispositivo"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#0F1B2D" />
                <TextView
                    android:id="@+id/tvDeviceID"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID GLPI: #—"
                    android:textSize="12sp"
                    android:textColor="#9BABB8" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DETALHES DO ATIVO"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#9BABB8"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvDeviceSerialDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/N: —"
                    android:textSize="14sp"
                    android:textColor="#1E2D3D"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvDeviceLocationDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Local: —"
                    android:textSize="14sp"
                    android:textColor="#1E2D3D"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvDeviceComment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Observações..."
                    android:textSize="13sp"
                    android:textColor="#4A6380"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VINCULAR RESPONSÁVEL"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#9BABB8"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilUserSearch"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Buscar colaborador..."
            android:layout_marginBottom="12dp"
            app:startIconDrawable="@android:drawable/ic_menu_search">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUserSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSelectedUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#BBF7D0"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="#F0FDF4"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvSelectedUserName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Colaborador Selecionado"
                    android:textColor="#16A34A"
                    android:textStyle="bold" />
                <ImageButton
                    android:id="@+id/btnRemoveSelectedUser"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#6B7280" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TERMO DE RESPONSABILIDADE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#9BABB8"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAttachTerm"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Anexar Foto do Termo"
            app:icon="@android:drawable/ic_menu_camera"
            android:layout_marginBottom="24dp" />

        <ProgressBar
            android:id="@+id/progressDetail"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmLink"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CONFIRMAR VÍNCULO"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            android:backgroundTint="#0F1B2D" />

    </LinearLayout>
</ScrollView>
